# ==================== SERVER CONFIGURATION ====================
PORT=5000
JWT_SECRET=my_super_secret_key_123456789
# Environment (development, production, test)
NODE_ENV=development

# ==================== SECURITY ====================
# JWT Secret - Change this to a strong secret in production
JWT_SECRET=agileflow_super_secret_key_2024_change_this_in_production

# JWT Expiration (7 days)
JWT_EXPIRES_IN=7d

# ==================== DATABASE ====================
# SQLite Database Path
DB_PATH=../database/agile.db

# ==================== EMAIL CONFIGURATION ====================
# Gmail SMTP Settings
EMAIL_USER=rantdev9179@gmail.com
EMAIL_PASS=jurosuleurlglkfa

# Email From Address (can be same as EMAIL_USER)
EMAIL_FROM=noreply@agileflow.com

# ==================== GOOGLE OAUTH ====================
# Google OAuth Client ID (for Google Login)
GOOGLE_CLIENT_ID=106987871275-ait10kap6dlq0coeos96r3q2g62i53fs.apps.googleusercontent.com

# Google OAuth Client Secret (keep this secret!)
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ==================== CLIENT CONFIGURATION ====================
# Frontend URL
CLIENT_URL=http://localhost:5173

# ==================== RATE LIMITING ====================
# Rate Limiting Window (15 minutes in milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Rate Limiting Max Requests per Window
RATE_LIMIT_MAX=100

# ==================== CORS ====================
# Allowed Origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== FILE UPLOADS ====================
# Max file size (5MB)
MAX_FILE_SIZE=5242880

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==================== LOGGING ====================
# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# ==================== SESSION ====================
# Session secret (if using sessions)
SESSION_SECRET=agileflow_session_secret_change_this

# ==================== API CONFIGURATION ====================
# API Prefix
API_PREFIX=/api

# API Version
API_VERSION=v1

# ==================== CRON JOBS ====================
# Reminder job schedule (daily at 9 AM)
REMINDER_JOB_SCHEDULE=0 9 * * *

# ==================== DEVELOPMENT ====================
# Enable debug mode
DEBUG=true

# Show SQL queries
SHOW_SQL_QUERIES=true

# ==================== PRODUCTION ====================
# Enable HTTPS (set to true in production)
ENABLE_HTTPS=false

# SSL Certificate paths (if HTTPS enabled)
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt

