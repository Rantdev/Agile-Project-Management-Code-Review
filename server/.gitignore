# Dependencies — must be installed fresh in the deployment container
# so that native modules (e.g. sqlite3) are compiled for the target OS/arch.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Lock files (regenerated on install)
package-lock.json
yarn.lock

# Environment files
.env
.env.local
.env.production
.env.development

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Uploads / generated files
uploads/
files/

# PM2
.pm2/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock
